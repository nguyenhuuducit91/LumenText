{
  "permissions": {
    "allow": [
      "Bash(node -c src/renderer/js/app.js)",
      "Bash(node -c preload.js)",
      "Bash(node node_modules/electron/install.js)",
      "Bash(echo \"install exit: $?\")",
      "Read(//tmp/**)",
      "Bash(env)",
      "Bash(timeout 12 curl -sI -o /dev/null -w \"HTTP %{http_code} in %{time_total}s\\\\n\" https://github.com/electron/electron/releases)",
      "Bash(node -c main.js)",
      "Bash(pkill -f \"node_modules/electron/dist/electron\")",
      "Bash(pkill -9 -f \"node_modules/electron/dist/electron\")",
      "Bash(pkill -9 -f \"electron/dist/electron\")",
      "Bash(awk '{print $2, $11, $12, $13}')",
      "Bash(awk '{print $2, $11, $12}')",
      "Bash(ps -p 141893 -o pid=)"
    ]
  }
}
